{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index"
    },
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/waitlist",
      "destination": "/api/waitlist"
    },
    {
      "source": "/api/referral",
      "destination": "/api/referral"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
